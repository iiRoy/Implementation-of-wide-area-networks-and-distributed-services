  <property name="styleSheet">
   <string notr="true">QMainWindow, QWidget {
    background-color: #081120;
    color: #e6edf7;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
}

QWidget#centerHeaderContainer,
QWidget#rightHeaderContainer {
    background-color: transparent;
    border: none;
}

/* Fondo base de pestañas */
QTabWidget::pane {
    border: none;
    background-color: transparent;
}

/* Tabs */
QTabBar::tab {
    background-color: #18253a;
    color: #c9d4e5;
    padding: 10px 22px;
    min-width: 130px;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    margin-right: 6px;
    font-weight: 600;
}

QTabBar::tab:selected {
    background-color: #4a8cff;
    color: white;
}

QTabBar::tab:hover:!selected {
    background-color: #22324d;
}

/* Cards principales */
QFrame#headerCard,
QFrame#principalPageCard,
QFrame#aboutPageCard,
QFrame#leftPanel,
QFrame#rightPanel,
QFrame#ruleEditorCard,
QFrame#executionCard,
QFrame#infoPanel,
QFrame#cardProyecto,
QFrame#cardEquipo {
    background-color: #111c2e;
    border: 1px solid #24344c;
    border-radius: 18px;
}

/* Header superior */
QFrame#headerCard {
    background-color: #132238;
    border-radius: 18px;
}

/* Paneles internos un poco más oscuros */
QFrame#ruleEditorCard,
QFrame#executionCard,
QFrame#infoPanel,
QFrame#cardProyecto,
QFrame#cardEquipo {
    background-color: #0d1727;
    border: 1px solid #2e4260;
    border-radius: 16px;
}

/* Labels base */
QLabel {
    background: transparent;
    border: none;
    color: #e6edf7;
}

/* Títulos */
QLabel#lblUploadTitle,
QLabel#lblRulesTitle,
QLabel#lblRuleEditorTitle,
QLabel#lblAboutTitle,
QLabel#lblProyectoInfo,
QLabel#lblLogoProyecto,
QLabel#lblEquipo {
    color: #f8fbff;
    font-size: 15pt;
    font-weight: 700;
}

/* Subtítulos / apoyo */
QLabel#lblUploadHint,
QLabel#lblCantidadImagenes,
QLabel#lblPreviewNombre,
QLabel#lblSeleccionImagenesTitulo,
QLabel#lblAboutSubtitle,
QLabel#lblResumenSeleccion {
    color: #91a4bf;
    font-size: 10.5pt;
}

/* Botones */
QPushButton, QToolButton {
    background-color: #4a8cff;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 10px 16px;
    font-weight: 600;
}

QPushButton:hover, QToolButton:hover {
    background-color: #3a7af0;
}

QPushButton:pressed, QToolButton:pressed {
    background-color: #2d67d0;
}

QPushButton:disabled, QToolButton:disabled {
    background-color: #40516a;
    color: #bcc7d6;
}

/* Inputs */
QLineEdit, QComboBox, QSpinBox {
    background-color: #0a1423;
    color: #e6edf7;
    border: 1px solid #385174;
    border-radius: 12px;
    padding: 8px 12px;
    min-height: 24px;
}

QLineEdit:focus, QComboBox:focus, QSpinBox:focus {
    border: 1px solid #4a8cff;
}

/* Combobox popup */
QComboBox::drop-down {
    border: none;
    width: 24px;
    background: transparent;
}

QComboBox QAbstractItemView {
    background-color: #0d1727;
    color: #e6edf7;
    border: 1px solid #2c405d;
    selection-background-color: #4a8cff;
    selection-color: white;
}

/* Lista de imágenes */
QListWidget {
    background-color: #091426;
    color: #e6edf7;
    border: 1px solid #314866;
    border-radius: 16px;
    padding: 8px;
}

QListWidget::item {
    background-color: #122036;
    border: 1px solid #233754;
    border-radius: 10px;
    margin: 6px;
    padding: 8px;
}

QListWidget::item:selected {
    background-color: #1e3f79;
    border: 1px solid #4a8cff;
    color: white;
}

/* Tabla */
QTableWidget {
    background-color: #091426;
    color: #e6edf7;
    border: 1px solid #314866;
    border-radius: 16px;
    gridline-color: #1e2d45;
    selection-background-color: #1e3f79;
    selection-color: white;
}

QHeaderView::section {
    background-color: #22324a;
    color: #f8fbff;
    padding: 10px;
    border: none;
    font-weight: 700;
}

QTableCornerButton::section {
    background-color: #22324a;
    border: none;
}

/* QTextBrowser */
QTextBrowser {
    background-color: transparent;
    color: #e6edf7;
    border: none;
    padding: 4px;
    selection-background-color: #1e3f79;
    selection-color: white;
}

/* Scrollbars */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 4px 2px 4px 2px;
}

QScrollBar::handle:vertical {
    background: #425978;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #567095;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 2px 4px 2px 4px;
}

QScrollBar::handle:horizontal {
    background: #425978;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: #567095;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}</string>
