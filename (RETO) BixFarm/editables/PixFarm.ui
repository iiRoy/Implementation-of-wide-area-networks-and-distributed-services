&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Adwaita Sans'; font-weight:700;&quot;&gt;Grupo: &lt;/span&gt;&lt;span style=&quot; font-family:'Adwaita Sans';&quot;&gt;501&lt;/span&gt;&lt;/p&gt;
&lt;p style=&quot; margin-top:0px; margin-bottom:0px; margin-left:0px; margin-right:0px; -qt-block-indent:0; text-indent:0px;&quot;&gt;&lt;span style=&quot; font-family:'Adwaita Sans'; font-weight:700;&quot;&gt;Código: &lt;/span&gt;&lt;span style=&quot; font-family:'Adwaita Sans';&quot;&gt;TC3003B.501&lt;/span&gt;&lt;/p&gt;
