  <property name="styleSheet">
   <string notr="true">QDialog#DialogSeleccionImagenes, QWidget {
    background-color: #081120;
    color: #e6edf7;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
}

QWidget#dlgSelMainContainer {
    background-color: transparent;
}

QWidget#dlgSelButtonsRow {
    background-color: #111c2e;
    border: 1px solid #24344c;
    border-radius: 16px;
}

QLabel#lblSelTitulo {
    color: #f8fbff;
    font-size: 15pt;
    font-weight: 700;
    background: transparent;
    border: none;
}

QListWidget#listSeleccionImagenes {
    background-color: #0d1727;
    color: #e6edf7;
    border: 1px solid #2e4260;
    border-radius: 16px;
    padding: 8px;
    outline: none;
}

QListWidget#listSeleccionImagenes::item {
    background-color: #122036;
    border: 1px solid #233754;
    border-radius: 10px;
    margin: 6px;
    padding: 10px;
}

QListWidget#listSeleccionImagenes::item:selected {
    background-color: #1e3f79;
    border: 1px solid #4a8cff;
    color: white;
}

QPushButton {
    background-color: #4a8cff;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 10px 16px;
    font-weight: 600;
    min-height: 22px;
}

QPushButton:hover {
    background-color: #3a7af0;
}

QPushButton:pressed {
    background-color: #2d67d0;
}

QPushButton#btnCancelarSeleccion {
    background-color: #1a2638;
    border: 1px solid #324863;
    color: #d7e2f0;
}

QPushButton#btnCancelarSeleccion:hover {
    background-color: #22324a;
}

/* Scrollbar vertical */
QScrollBar:vertical {
    background: transparent;
    width: 10px;
    margin: 4px 2px 4px 2px;
}

QScrollBar::handle:vertical {
    background: #425978;
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: #567095;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

/* Scrollbar horizontal */
QScrollBar:horizontal {
    background: transparent;
    height: 10px;
    margin: 2px 4px 2px 4px;
}

QScrollBar::handle:horizontal {
    background: #425978;
    border-radius: 5px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background: #567095;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}</string>
