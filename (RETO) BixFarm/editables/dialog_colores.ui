  <property name="styleSheet">
   <string notr="true">QDialog#DialogColores, QWidget {
    background-color: #081120;
    color: #e6edf7;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
}

QWidget#dlgMainContainer {
    background-color: transparent;
}

QWidget#dlgTitleCard,
QFrame#dlgButtonsRow,
QFrame#dlgChecksRow {
    background-color: #111c2e;
    border: 1px solid #24344c;
    border-radius: 16px;
}

/* Título */
QLabel#lblDialogTitulo {
    color: #f8fbff;
    font-size: 16pt;
    font-weight: 700;
    background: transparent;
    border: none;
}

/* Descripción */
QLabel#lblDialogDescripcion {
    color: #91a4bf;
    font-size: 10.5pt;
    background: transparent;
    border: none;
}

/* Checkboxes */
QCheckBox {
    color: #e6edf7;
    spacing: 8px;
    background: transparent;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    border: 1px solid #385174;
    background-color: #0a1423;
}

QCheckBox::indicator:hover {
    border: 1px solid #4a8cff;
}

QCheckBox::indicator:checked {
    background-color: #4a8cff;
    border: 1px solid #4a8cff;
}

/* Botones */
QPushButton {
    background-color: #4a8cff;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 10px 16px;
    font-weight: 600;
    min-height: 22px;
}

QPushButton:hover {
    background-color: #3a7af0;
}

QPushButton:pressed {
    background-color: #2d67d0;
}

/* Botón cancelar diferente */
QPushButton#btnCancelarColor {
    background-color: #1a2638;
    border: 1px solid #324863;
    color: #d7e2f0;
}

QPushButton#btnCancelarColor:hover {
    background-color: #22324a;
}

/* Separadores visuales suaves */
QFrame {
    color: #24344c;
}</string>
